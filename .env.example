# ── Sukoon environment ──────────────────────────────────────────────
# Everything is OPTIONAL for local preview: with no keys, Sukoon runs in
# "local mode" (data in your browser, warm scripted companion responses).
# Add keys to switch on the real AI + cloud persistence.

# ── Live Claude: pick ONE of the two below (you don't need both) ──────
#
# Option A — Anthropic API key (direct). Get one at https://console.anthropic.com
# Calls Claude directly via @ai-sdk/anthropic. Simplest if you already have a key.
ANTHROPIC_API_KEY=
#
# Option B — Vercel AI Gateway key. Get one at https://vercel.com/ai-gateway
# Routes "anthropic/<model>" through the gateway (no Anthropic key needed).
# If both are set, the Anthropic key wins.
AI_GATEWAY_API_KEY=

# Optional: protects the proactive cron endpoint in production.
# Vercel Cron sends this automatically when set as a project env var.
CRON_SECRET=

# ── Supabase (production persistence) ───────────────────────────────
# Free tier: https://supabase.com . Run supabase/migrations/0001_init.sql
# in the SQL editor, then fill these in. Leave blank to use local mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
